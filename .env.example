# Copy this file to .env and fill in your values.
# .env is gitignored and will never be committed.

# ── Database ───────────────────────────────────────────────────────────────────
# Matches the docker-compose.yml defaults. Change if using a remote DB.
DATABASE_URL=postgresql+asyncpg://hippo:hippo@localhost:5432/hippo

# ── LLM / embeddings ──────────────────────────────────────────────────────────
# Set ONE of the following. Hippo auto-detects which backend to use.

# Option A: OpenAI (embeddings + conflict LLM)
OPENAI_API_KEY=sk-...

# Option B: Groq for conflict LLM + local sentence-transformers for embeddings
# (free tier available at console.groq.com — no credit card required)
# GROQ_API_KEY=gsk-...

# ── Optional overrides ────────────────────────────────────────────────────────
# Override the LLM model used for conflict detection
# CONFLICT_MODEL=gpt-4o-mini

# Use a separate DB for tests (avoids wiping your dev data)
# TEST_DATABASE_URL=postgresql+asyncpg://hippo:hippo@localhost:5432/hippo_test
